# ══════════════════════════════════════════════════════════════════════════════
# CoTrader .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── Build Artifacts ──────────────────────────────────────────────────────────
target/
*.o
*.d
*.rlib
*.rmeta
*.pdb

# ── Environment & Secrets ────────────────────────────────────────────────────
.env
.env.*
rat.env
config/rat.env
*.secret
*.key

# ── Local Databases ──────────────────────────────────────────────────────────
*.db
*.db-journal
*.db-wal
*.db-shm
storage/*.db
storage/*.db-journal
storage/*.db-wal
storage/*.db-shm

# ── Logs & Temporary Files ───────────────────────────────────────────────────
*.log
logs/
data/logs/
*.jsonl
tri_level_reasoning.jsonl

# ── Model Cache ──────────────────────────────────────────────────────────────
.fastembed_cache/
data/cache/
models/
*.safetensors
*.gguf

# ── Exception: Rust source files in models/ directories ──────────────────────
!crates/*/src/models/

# ── OS-Specific ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── IDE & Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── Rust-Specific ────────────────────────────────────────────────────────────
Cargo.lock

# ── Runtime Artifacts ────────────────────────────────────────────────────────
*.pid
*.sock
*.tmp

# ── Research Artifacts (not for production) ──────────────────────────────────
survey/
*.research.json

# ── Docker ───────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ── Node (for MiMoCode tooling) ─────────────────────────────────────────────
.mimocode/node_modules/
.mimocode/plans/
